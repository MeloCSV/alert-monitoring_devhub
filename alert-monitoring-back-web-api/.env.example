# Base de datos
DATABASE_HOST=127.0.0.1:5432
DATABASE_USERNAME=sa
DATABASE_PASSWORD=root
DATABASE=alert_monitoring

# Framework
ENVIRONMENT=local
FWK_PATH=alert_monitoring/api

# OpenTelemetry (requiere docker-compose-observability.yaml levantado)
OTEL_SERVICE_NAME=alert-monitoring-back-web-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:55681
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://localhost:55681/v1/metrics
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_METRICS_EXPORTER=otlp
OTEL_TRACES_EXPORTER=otlp
OTEL_TRACES_SAMPLER=always_on
# Nivel de trazas: 0=app, 1=libs publicas, 2=libs privadas (por defecto: 0)
# FWK_TRACE_LEVEL=0
